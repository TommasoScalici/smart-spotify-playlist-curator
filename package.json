{
  "name": "smart-spotify-playlist-curator",
  "version": "1.12.0",
  "description": "A powerful automation system that curates Spotify playlists using **Google Gemini 2.5 Flash** for intelligent song recommendations and **Firebase Cloud Functions** for serverless orchestration.",
  "workspaces": [
    "shared",
    "web-app",
    "functions",
    "scripts"
  ],
  "main": "index.js",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=web-app",
    "deploy-firebase": "tsx scripts/src/admin/build.ts && firebase deploy",
    "dry-run-release": "semantic-release",
    "fix": "npm run type-check && npm run lint:fix && npm run format",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "type-check": "tsc -b",
    "test": "npm run test --workspaces --if-present"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "web-app/**/*.{ts,tsx}": [
      "npm run lint --prefix web-app"
    ],
    "functions/**/*.{ts,js}": [
      "npm run lint --prefix functions --"
    ],
    "scripts/**/*.{ts,js}": [
      "npm run lint --prefix scripts --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TommasoScalici/smart-spotify-playlist-curator.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TommasoScalici/smart-spotify-playlist-curator/issues"
  },
  "homepage": "https://github.com/TommasoScalici/smart-spotify-playlist-curator#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "fast-xml-parser": "5.3.7",
    "minimatch": "10.2.1",
    "eslint-plugin-react-hooks": {
      "eslint": "^10.0.1"
    }
  }
}
